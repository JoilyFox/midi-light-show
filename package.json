{
  "name": "midi-light-show",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Local control + MIDI-driven light shows for smart lamps/LEDs (Phase 1: WiZ manual control MVP)",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "tsx src/server.ts",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@julusian/midi": "^3.6.1",
    "express": "^4.19.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "prettier": "^3.3.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0"
  }
}
